rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidLead(data) {
      return data.name is string && data.name.size() <= 200 &&
             data.phone is string && data.phone.size() <= 30;
    }

    // Leads collection
    match /leads/{leadId} {
      allow list, get: if true;
      allow create: if isValidLead(request.resource.data);
      allow delete: if false; // Prevention of global data deletion
    }
  }
}
